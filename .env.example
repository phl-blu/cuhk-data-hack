# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/greenloop

# S3-compatible object storage
S3_BUCKET=greenloop-photos
S3_REGION=us-east-1
S3_ACCESS_KEY=your_access_key_here
S3_SECRET_KEY=your_secret_key_here
S3_ENDPOINT=https://s3.amazonaws.com

# Mapbox
MAPBOX_TOKEN=pk.your_mapbox_token_here

# Material sorter WebSocket (Railway service URL)
# e.g. wss://your-sorter.up.railway.app/ws/classify
VITE_SORTER_WS_URL=wss://your-sorter.up.railway.app/ws/classify

# Ingestion scheduler
INGEST_INTERVAL_HOURS=24

# Server
PORT=3000
