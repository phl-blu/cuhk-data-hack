# These work as-is with docker-compose — no changes needed
DATABASE_URL=postgres://postgres:postgres@localhost:5432/greenloop
PORT=3000
INGEST_INTERVAL_HOURS=24

# Skip S3 for now — photo upload won't work but everything else will
S3_BUCKET=greenloop-photos
S3_REGION=us-east-1
S3_ACCESS_KEY=placeholder
S3_SECRET_KEY=placeholder
S3_ENDPOINT=https://s3.amazonaws.com

# Get a free token at mapbox.com — needed for the map tab later
MAPBOX_TOKEN=pk.your_mapbox_token_here
VITE_MAPBOX_TOKEN=pk.your_mapbox_token_here
